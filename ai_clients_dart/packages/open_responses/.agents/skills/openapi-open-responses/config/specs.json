{
  "specs": {
    "main": {
      "name": "OpenResponses API",
      "url": "https://www.openresponses.org/openapi/openapi.json",
      "local_file": "openapi.json",
      "requires_auth": false,
      "auth_env_vars": [],
      "description": "OpenResponses unified LLM API specification",
      "fetch_mode": "remote",
      "audit": {
        "excluded_schemas": [],
        "schema_aliases": {},
        "reference_impl": {
          "repo": "openai/openai-python",
          "ref": "main",
          "resources": {
            "adapter": "python_stainless_resources",
            "path": "src/openai/resources/responses"
          },
          "types": {
            "adapter": "python_init_exports",
            "path": "src/openai/types/responses/__init__.py"
          }
        }
      }
    }
  },
  "specs_dir": "packages/open_responses/specs",
  "output_dir": "/tmp/openapi-open-responses-dart"
}
