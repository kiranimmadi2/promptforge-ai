{
  "specs": {
    "main": {
      "name": "Generative Language API",
      "url": "https://generativelanguage.googleapis.com/$discovery/OPENAPI3_0?version=v1beta",
      "local_file": "openapi.json",
      "requires_auth": true,
      "auth_env_vars": [
        "GEMINI_API_KEY",
        "GOOGLE_AI_API_KEY"
      ],
      "auth": {
        "location": "header",
        "name": "x-goog-api-key",
        "prefix": ""
      },
      "description": "Core Gemini API - generation, embeddings, files, models, etc.",
      "fetch_mode": "remote",
      "audit": {
        "excluded_schemas": [],
        "schema_aliases": {},
        "reference_impl": {
          "repo": "googleapis/python-genai",
          "ref": "main",
          "resources": {
            "adapter": "python_client_members",
            "path": "google/genai/client.py",
            "class_name": "Client"
          },
          "types": {
            "adapter": "python_single_file_classes",
            "path": "google/genai/types.py"
          }
        }
      }
    },
    "interactions": {
      "name": "Interactions API",
      "url": "https://ai.google.dev/static/api/interactions.openapi.json",
      "local_file": "openapi-interactions.json",
      "requires_auth": false,
      "auth_env_vars": [],
      "experimental": true,
      "description": "Server-side state, agents, background execution",
      "fetch_mode": "remote",
      "audit": {
        "excluded_schemas": [],
        "schema_aliases": {},
        "reference_impl": {
          "repo": "googleapis/python-genai",
          "ref": "main",
          "resources": {
            "adapter": "python_client_members",
            "path": "google/genai/client.py",
            "class_name": "Client",
            "include": [
              "interactions"
            ]
          },
          "types": {
            "adapter": "python_init_exports",
            "path": "google/genai/_interactions/types/__init__.py"
          }
        }
      }
    }
  },
  "specs_dir": "packages/googleai_dart/specs",
  "output_dir": "/tmp/openapi-googleai-dart"
}
